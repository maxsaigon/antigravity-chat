{
  "name": "antigravity-telegram-bridge",
  "displayName": "Telegram Bridge for Antigravity",
  "description": "Connects Antigravity Agent to Telegram for remote chat and control. v0.5.5: Simplified commands (/ok /no /stop /conv).",
  "version": "0.5.6",
  "publisher": "daibui",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Telegram Bridge",
      "properties": {
        "telegramBridge.botToken": {
          "type": "string",
          "default": "",
          "description": "The Bot Token obtained from @BotFather on Telegram."
        },
        "telegramBridge.userId": {
          "type": "string",
          "default": "",
          "description": "Your Telegram User ID (to restrict access)."
        },
        "telegramBridge.statusNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Send proactive status change notifications (Online/Thinking/Working/Idle/Offline) to Telegram."
        }
      }
    },
    "commands": [
      {
        "command": "telegramBridge.start",
        "title": "Telegram Bridge: Start Bot"
      },
      {
        "command": "telegramBridge.stop",
        "title": "Telegram Bridge: Stop Bot"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "node-telegram-bot-api": "^0.65.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/vscode": "~1.106.0",
    "typescript": "^5.9.3"
  }
}