{
  "name": "antigravity-api-test",
  "displayName": "Antigravity API Test",
  "description": "Test extension for probing Antigravity APIs and output capture strategies",
  "version": "0.0.3",
  "publisher": "daibui",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apiTest.sendPrompt",
        "title": "API Test: sendPromptToAgentPanel"
      },
      {
        "command": "apiTest.probeAll",
        "title": "API Test: Probe ALL"
      },
      {
        "command": "apiTest.watchBrain",
        "title": "API Test: Brain Artifact Watcher"
      },
      {
        "command": "apiTest.diagPoll",
        "title": "API Test: Smart Diagnostics Poll"
      },
      {
        "command": "apiTest.watchSqlite",
        "title": "API Test: SQLite State Watcher"
      },
      {
        "command": "apiTest.roundTripV2",
        "title": "API Test: Round Trip v2"
      },
      {
        "command": "apiTest.watchLogs",
        "title": "API Test: Watch Runtime Logs"
      },
      {
        "command": "apiTest.monitorOutputs",
        "title": "API Test: Monitor VS Code Events"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "~1.107.0",
    "typescript": "^5.9.3"
  }
}
